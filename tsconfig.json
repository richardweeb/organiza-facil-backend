{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "verbatimModuleSyntax": false,

    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "declaration": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src"],
  "exclude": ["dist", "src/**/*.js"]
}