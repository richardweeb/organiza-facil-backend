{
  "openapi": "3.0.3",
  "info": {
    "title": "Organiza Fácil API",
    "version": "1.0.0",
    "description": "API do Organiza Fácil (Telegram/WhatsApp-ready)."
  },
  "servers": [{ "url": "http://localhost:3000" }],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/user/admin/stats": {
      "get": {
        "summary": "Admin stats",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/user/banned": {
      "get": {
        "summary": "List banned users",
        "parameters": [
          {
            "name": "activeOnly",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["0", "1"] }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
